# ============================================================================
# TradeFlow Backend — Environment Variables
# Copy this to .env and fill in your values (never commit .env!)
# ============================================================================

# MySQL Database (use your cloud provider's connection string)
# For Aiven: jdbc:mysql://your-host:port/your-db?useSSL=true&requireSSL=true
# For PlanetScale: jdbc:mysql://your-host:3306/your-db?sslMode=VERIFY_IDENTITY
# For Railway: jdbc:mysql://your-host:port/railway
DATABASE_URL=jdbc:mysql://localhost:3306/tradeflow_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DATABASE_USERNAME=root
DATABASE_PASSWORD=your_password_here

# JWT Secret — generate with: openssl rand -base64 64
JWT_SECRET=dHJhZGVmbG93LXNlY3JldC1rZXktZm9yLWp3dC10b2tlbi1zaWduaW5nLXRoaXMtc2hvdWxkLWJlLWxvbmctZW5vdWdoLWZvci1obWFjLXNoYTUxMg==

# CORS — comma-separated allowed origins
CORS_ORIGINS=https://vansh-jyotishi.github.io

# Logging
LOG_LEVEL=INFO

# Connection pool (keep low on free tier)
HIKARI_MAX_POOL=5
